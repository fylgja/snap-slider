{
  "name": "@fylgja/snap-slider",
  "version": "2.2.2",
  "description": "A CSS-powered slider/carousel, enhanced with JavaScript for improved functionality and accessibility",
  "homepage": "https://fylgja.dev/",
  "author": "Fylgja",
  "license": "MIT",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "unpkg": "dist/custom-element/index.min.js",
  "jsdelivr": "dist/custom-element/index.min.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./custom-element": {
      "import": "./dist/custom-element/index.js",
      "require": "./dist/custom-element/index.cjs",
      "default": "./dist/custom-element/index.cjs"
    },
    "./alpine": {
      "import": "./dist/alpine/index.js",
      "require": "./dist/alpine/index.cjs",
      "default": "./dist/alpine/index.cjs"
    },
    "./*": "./*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fylgja/snap-slider"
  },
  "bugs": "https://github.com/fylgja/snap-slider/issues",
  "keywords": [
    "fylgja",
    "slider",
    "carousel",
    "custom-element"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "prebuid": "rm -rf ./dist",
    "build": "node ./scripts/build.js"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
