{
  "name": "@fylgja/snap-slider",
  "version": "1.0.0",
  "description": "A CSS-powered slider/carousel, enhanced with JavaScript for improved functionality and accessibility",
  "homepage": "https://fylgja.dev/",
  "author": "Fylgja",
  "license": "MIT",
  "main": "dist/index.cjs",
  "unpkg": "dist/index.min.js",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./alpinejs": {
      "import": "./dist/alpine.mjs",
      "require": "./dist/alpine.cjs",
      "default": "./dist/alpine.cjs"
    },
    "./*": "./*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fylgja/snap-slider"
  },
  "bugs": "https://github.com/fylgja/snap-slider/issues",
  "keywords": [
    "fylgja",
    "slider",
    "carousel",
    "custom-element"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "prebuid": "rm -rf ./dist",
    "build": "node ./scripts/build.js"
  },
  "devDependencies": {
    "esbuild": "^0.25.2"
  }
}
